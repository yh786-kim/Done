# ===== Supabase =====
# Supabase 대시보드 > Project Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role 키 (서버 전용, 절대 클라이언트 노출 금지)

# ===== 앱 주소 =====
# 로컬: http://localhost:3000 / 배포: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== 세션 서명 비밀키 =====
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me

# ===== 웹 푸시(VAPID) =====
# node -e "const w=require('web-push');console.log(w.generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ===== 스케줄러(cron) 보호용 비밀 =====
CRON_SECRET=change-me

# ===== 문자(SMS) 발송 =====
# 값이 없으면 개발 모드: 인증 링크를 화면/콘솔에 그대로 표시(실제 문자 미발송)
# 실제 서비스: Solapi 등 연동 (아래는 예시, src/lib/sms.ts 참고)
SMS_PROVIDER=          # 비워두면 mock
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=         # 발신번호
